# ===== AI Judge / RAG Reference Generation =====
# Which provider to use by default for the AI judge and reference-answer generation.
# Options: anthropic | gemini | openai | ollama
AI_JUDGE_PROVIDER=ollama

# --- Anthropic Claude (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Ollama (local, no key required) ---
# Install: https://ollama.com  →  then `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Per-call timeout (seconds) for AI judge network requests. If exceeded the
# API returns HTTP 504 so the UI does not hang on a stuck provider.
JUDGE_TIMEOUT_SECONDS=30.0

# ===== Storage =====
# Where SQLite, Chroma, uploaded docs, and the embeddings cache live (relative to ./server).
DATA_DIR=./data

# Set to true to skip seeding the demo "Sample Support Bot" project on startup.
# The seed is idempotent (only runs once, when no project with that name exists),
# so you usually only need this if you're scripting tests against an empty DB.
SEED_PROJECT_DISABLED=false
